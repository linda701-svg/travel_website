# Environment variables for the backend

# JWT Settings
# IMPORTANT: Replace YOUR_VERY_SECRET_KEY with a long, random, and secret string.
# You can generate one from here: https://www.grc.com/passwords.htm
JWT_SECRET=YOUR_VERY_SECRET_KEY
JWT_EXPIRE=30d

# MongoDB Connection
# Replace with your own MongoDB connection string if needed
MONGO_URI=mongodb://localhost:27017/travel_db
